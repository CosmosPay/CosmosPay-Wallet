# CosmosPay configuration. Copy to `.env` and adjust. Vite only exposes vars
# prefixed with PUBLIC_ to the browser bundle, so NEVER put secrets in PUBLIC_*.

# --- Client base URLs (shipped to the browser) ---
# DEV: leave these EMPTY. The app then calls same-origin (/api, /v1) and the
# Vite dev proxy (see astro.config.ts) forwards to the targets below — no CORS.
# PROD / NATIVE: set absolute URLs, e.g. https://developers.cosmospay.io
PUBLIC_COSMOS_DEV_PLATFORM_URL=
PUBLIC_COSMOS_GATEWAY_URL=

# Vite dev-proxy targets (Node-side only — NOT shipped to the client bundle).
# Developer-Platform (Astro, provisioning /api/wallet/*) runs on 4321.
COSMOS_DEV_PLATFORM_PROXY=https://dev.cosmospay.lat
# APISIX gateway (payments /v1/*). community-server sits behind it on :3000.
COSMOS_GATEWAY_PROXY=https://api.cosmospay.lat
