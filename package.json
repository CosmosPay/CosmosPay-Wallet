{
  "name": "cosmos-stellar-wallet",
  "version": "1.2.1",
  "private": true,
  "type": "module",
  "description": "Cosmos — a non-custodial Stellar wallet (Astro + Preact + Capacitor)",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "serve:dist": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/serve-dist.ts",
    "demo": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/serve-demo.ts",
    "build:ext": "astro build && node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/build-extension.ts",
    "build:ext:firefox": "astro build && node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/build-extension.ts firefox",
    "test:e2e": "node --disable-warning=ExperimentalWarning --experimental-strip-types tests/wallet.e2e.ts",
    "test:responsive": "node --disable-warning=ExperimentalWarning --experimental-strip-types tests/responsive.e2e.ts",
    "cap:sync": "astro build && cap sync",
    "cap:android": "astro build && cap sync android && cap open android",
    "cap:ios": "astro build && cap sync ios && cap open ios"
  },
  "dependencies": {
    "@astrojs/react": "^6.0.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/clipboard": "^8.0.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/preferences": "^8.0.1",
    "@stellar/stellar-sdk": "^16.0.1",
    "astro": "^7.0.7",
    "bip39": "^3.1.0",
    "country-flag-icons": "^1.6.20",
    "ed25519-hd-key": "^2.0.0",
    "jsqr": "^1.4.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@capacitor/cli": "^8.4.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "playwright": "^1.61.1",
    "typescript": "^7.0.2",
    "vite-plugin-node-polyfills": "^0.28.0"
  },
  "overrides": {
    "yaml": "^2.9.0",
    "elliptic": "^6.6.1",
    "typescript": "^7.0.2"
  }
}